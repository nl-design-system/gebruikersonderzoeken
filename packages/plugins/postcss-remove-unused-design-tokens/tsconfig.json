{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["@nl-design-system/tsconfig"],
  "include": ["**/*"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "baseUrl": ".",
    "verbatimModuleSyntax": true,
    "allowSyntheticDefaultImports": true,
    "checkJs": true,
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "noEmit": true
  }
}
