{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "Node",
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"jsxImportSource": "jsx-async-runtime",
		"allowJs": true,
		"include": [
			"components",
			"site",
			"_includes",
			"**/*.tsx"
		],
		"exclude": [
			"node_modules",
			"_site"
		]
	}
}
